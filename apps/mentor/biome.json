{
	"root": false,
	"$schema": "../../biome.json",
	"linter": {
		"rules": {
			"a11y": {
				"noSvgWithoutTitle": "off"
			},
			"correctness": {
				"noUnusedImports": "off"
			},
			"suspicious": {
				"noUnknownAtRules": "off"
			},
			"complexity": {
				"noUselessFragments": "off"
			}
		}
	}
}
